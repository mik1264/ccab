# Anthropic API key — used by Claude Haiku for receipt OCR
ANTHROPIC_API_KEY=sk-ant-...

# SMTP — for the weekly email report (optional; leave SMTP_HOST empty to skip)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=you@example.com
SMTP_TO=you@example.com
SMTP_USE_TLS=true

# Weekly run schedule (cron syntax, local time). Default: Friday 9pm
REPORT_CRON=0 21 * * fri
TIMEZONE=America/Los_Angeles

# Optional HTTP basic auth on the web UI. Leave blank to disable.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Storage paths (relative to project root)
DATA_DIR=data
STORAGE_DIR=storage
DATABASE_URL=sqlite:///data/receipts.db
